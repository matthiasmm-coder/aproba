# ─────────────────────────────────────────────────────────────────────────────
# Aproba — variables d'environnement (modèle).
#   • En local   → copie dans .env.local
#   • En prod    → renseigne ces variables dans Vercel (Project → Settings →
#                  Environment Variables), PAS dans un fichier committé.
# .env / .env.local / .env*.local sont gitignorés. NE JAMAIS committer de vraie clé.
# Voir DEPLOY.md pour la procédure complète de mise en production.
# ─────────────────────────────────────────────────────────────────────────────

# ── Supabase (base, auth, storage) ───────────────────────────────────────────
# Supabase → Project Settings → API
# Publics (envoyés au navigateur, sans danger) :
NEXT_PUBLIC_SUPABASE_URL="https://TON-REF.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJhbGciOi...anon..."
# Secret SERVEUR uniquement (bypass RLS — jamais exposé au client) :
SUPABASE_SERVICE_ROLE_KEY="eyJhbGciOi...service_role..."

# ── URL publique de l'app ─────────────────────────────────────────────────────
# Domaine canonique (sans / final). Sert aux URLs de retour Stripe et aux liens
# du portail dans les emails. En prod = https://aproba-software.com
# (si absent : déduit de l'origine de la requête).
NEXT_PUBLIC_APP_URL="https://aproba-software.com"

# ── Anthropic (validation IA des documents) ──────────────────────────────────
ANTHROPIC_API_KEY="sk-ant-..."

# ── Stripe (abonnement à Aproba) ──────────────────────────────────────────────
# TEST : sk_test_… (dev)  ·  PROD : sk_live_… (compte Aproba, après KYC + IBAN)
STRIPE_SECRET_KEY="sk_test_..."
# Secret du endpoint webhook. En dev = donné par `stripe listen` (éphémère).
# En prod = Stripe Dashboard → Developers → Webhooks → ton endpoint → Signing secret.
STRIPE_WEBHOOK_SECRET="whsec_..."

# ── Resend (emails d'avisos) ──────────────────────────────────────────────────
RESEND_API_KEY="re_..."
# Expéditeur vérifié (domaine aproba-software.com déjà validé dans Resend) :
AVISOS_EMAIL_FROM="avisos@aproba-software.com"
# Destinataire des retours du widget de feedback (ton email). Sans ça, le feedback
# est quand même stocké en base, mais tu n'es pas notifié par email.
FEEDBACK_NOTIFY_EMAIL="tu@email.com"

# ── Sentry (observabilité — optionnel) ───────────────────────────────────────
# Crée un projet Next.js sur sentry.io (gratuit) et colle le DSN. Sans ces clés,
# Sentry est désactivé (no-op). SENTRY_DSN = serveur, NEXT_PUBLIC_SENTRY_DSN = navigateur
# (le même DSN convient pour les deux).
SENTRY_DSN=""
NEXT_PUBLIC_SENTRY_DSN=""

# ── Optionnel ─────────────────────────────────────────────────────────────────
# Afficher l'encadré "Cuenta de demostración" sur /login en production (=1).
# Laisser vide/non défini pour le masquer (défaut en prod).
# NEXT_PUBLIC_SHOW_DEMO_LOGIN="1"

# DATABASE_URL n'est PAS utilisée par l'app (tout passe par l'API REST Supabase).
# Seulement nécessaire si un jour tu lances Prisma en direct :
# DATABASE_URL="postgresql://postgres.TON-REF:[MDP]@aws-0-eu-...pooler.supabase.com:5432/postgres?sslmode=require"
